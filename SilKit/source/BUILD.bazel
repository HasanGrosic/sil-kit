# ===========================================================================
# Unified internal headers
# ---------------------------------------------------------------------------
# The CMake build uses ~18 INTERFACE libraries (I_SilKit_Core_Internal,
# I_SilKit_Services_Can, I_SilKit_Tracing, ...) that form cyclic include
# dependencies.  Bazel forbids cyclic deps, so we merge every cycle-
# participating interface header set into this single target.
#
# Non-cycle leaf targets (util, config, wire) remain in their own packages.
# ===========================================================================

cc_library(
    name = "silkit_internal_headers",
    hdrs = glob(
        [
            "core/internal/**/*.hpp",
            "core/service/*.hpp",
            "core/requests/*.hpp",
            "core/requests/procs/*.hpp",
            "core/vasio/**/*.hpp",
            "core/participant/*.hpp",
            "services/can/*.hpp",
            "services/ethernet/*.hpp",
            "services/flexray/*.hpp",
            "services/lin/*.hpp",
            "services/logging/*.hpp",
            "services/orchestration/*.hpp",
            "services/pubsub/*.hpp",
            "services/rpc/*.hpp",
            "services/metrics/*.hpp",
            "tracing/**/*.hpp",
            "extensions/**/*.hpp",
            "extensions/**/*.h",
            "experimental/netsim/**/*.hpp",
            "experimental/participant/*.hpp",
            "experimental/services/**/*.hpp",
        ],
        exclude = [
            # Test mocks -- handled by dedicated test-only targets later
            "core/mock/**",
            "core/vasio/mock/**",
            "core/vasio/io/mock/**",
        ],
    ),
    defines = [
        "HAVE_FMTLIB",
        "FMT_HEADER_ONLY",
    ],
    includes = [
        "core/internal",
        "core/service",
        "core/requests",
        "core/requests/procs",
        "core/vasio",
        "core/vasio/io",
        "core/participant",
        "services/can",
        "services/ethernet",
        "services/flexray",
        "services/lin",
        "services/logging",
        "services/orchestration",
        "services/pubsub",
        "services/rpc",
        "services/metrics",
        "tracing",
        "tracing/mock",
        "extensions",
        "extensions/SilKitExtensionApi",
        "extensions/SilKitExtensionImpl",
        "experimental/netsim",
        "experimental",
    ],
    deps = [
        "//SilKit/include:silkit_interface",
        "//SilKit/source/config:silkit_config_interface",
        "//SilKit/source/util:silkit_util_interface",
        "//SilKit/source/util:silkit_util_uri_interface",
        "//SilKit/source/util:silkit_util_uuid_interface",
        "//SilKit/source/util:silkit_util_setthreadname_interface",
        "//SilKit/source/wire/util:silkit_wire_util_interface",
        "//SilKit/source/wire/can:silkit_wire_can_interface",
        "//SilKit/source/wire/ethernet:silkit_wire_ethernet_interface",
        "//SilKit/source/wire/flexray:silkit_wire_flexray_interface",
        "//SilKit/source/wire/lin:silkit_wire_lin_interface",
        "//SilKit/source/wire/pubsub:silkit_wire_pubsub_interface",
        "//SilKit/source/wire/rpc:silkit_wire_rpc_interface",
        "//ThirdParty:asio",
        "//ThirdParty:fmt",
        ":silkit_versionimpl_interface",
    ],
)

