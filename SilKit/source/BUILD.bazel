# --- Version macros (generated from version_macros.hpp.in) ---
# The version_macros rule reads STABLE_GIT_HASH from the workspace status
# file (written by bazel/print_workspace_status.sh) and substitutes it
# into the template alongside the hardcoded version numbers.
version_macros(
    name = "gen_version_macros",
    template = "version_macros.hpp.in",
    out = "version_macros.hpp",
)

cc_library(
    name = "version_macros",
    hdrs = [":gen_version_macros"],
    includes = ["."],
)

