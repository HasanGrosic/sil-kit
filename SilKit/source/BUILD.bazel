# ===========================================================================
# Force-include compilation unit
# ---------------------------------------------------------------------------
# SilKitForceIncludes.cpp calls inline C++ API wrappers (declared with
# DETAIL_SILKIT_CPP_API = inline) so the compiler emits definitions that the
# version-script (silkit.map) can then export from libSilKit.so.
# Without this, only the SilKit_* C API symbols appear in the dynamic table.
# ===========================================================================

cc_library(
    name = "silkit_force_includes",
    srcs = ["SilKitForceIncludes.cpp"],
    deps = [
        ":silkit_internal_headers",
        "//SilKit/include:silkit_interface",
    ],
    alwayslink = True,
)

# ===========================================================================
# S_SilKitImpl  -- static aggregate of all implementation libraries
# ---------------------------------------------------------------------------
# Mirrors the CMake S_SilKitImpl STATIC target that links all O_* objects.
# Used directly by sil-kit-registry (static linking).
# ===========================================================================

_SILKIT_IMPL_DEPS = [
    # core
    ":silkit_core_service",
    ":silkit_core_requestreply",
    ":silkit_core_requestreply_participantreplies",
    ":silkit_core_vasio",
    ":silkit_core_participant",
    # services
    ":silkit_services_can",
    ":silkit_services_ethernet",
    ":silkit_services_flexray",
    ":silkit_services_lin",
    ":silkit_services_logging",
    ":silkit_services_orchestration",
    ":silkit_services_pubsub",
    ":silkit_services_rpc",
    ":silkit_services_metrics",
    # tracing / extensions / experimental
    ":silkit_tracing",
    ":silkit_extensions",
    ":silkit_experimental_netsim",
    ":silkit_experimental",
    # root-level impl
    ":silkit_createparticipantimpl",
    ":silkit_createregistryimpl",
    ":silkit_versionimpl",
    # util impl
    "//SilKit/source/util:silkit_util",
    "//SilKit/source/util:silkit_util_filehelpers",
    "//SilKit/source/util:silkit_util_stringhelpers",
    "//SilKit/source/util:silkit_util_setthreadname",
    "//SilKit/source/util:silkit_util_signalhandler",
    "//SilKit/source/util:silkit_util_uuid",
    "//SilKit/source/util:silkit_util_uri",
    "//SilKit/source/util:silkit_util_labelmatching",
    # config impl
    "//SilKit/source/config:silkit_config",
    # capi
    "//SilKit/source/capi:silkit_capi",
    # dashboard (conditional on //bazel:dashboard_enabled)
    "//SilKit/source/dashboard:silkit_dashboard",
    # force-include compilation unit for C++ API exports
    ":silkit_force_includes",
]

cc_library(
    name = "S_SilKitImpl",
    deps = [":silkit_internal_headers"] + _SILKIT_IMPL_DEPS,
    alwayslink = True,
)

# ===========================================================================
# SilKit shared library
# ---------------------------------------------------------------------------
# Mirrors the CMake SilKit SHARED target.
# Uses a version script on Linux to control symbol visibility, and excludes
# bundled spdlog symbols from the export table.
# ===========================================================================

cc_shared_library(
    name = "SilKit",
    deps = [":S_SilKitImpl"],
    additional_linker_inputs = select({
        "//bazel:is_linux": ["silkit.map"],
        "//bazel:is_qnx": ["silkit.map"],
        "//conditions:default": [],
    }),
    user_link_flags = select({
        "//bazel:is_qnx": [
            "-Wl,--version-script=$(location silkit.map)",
            "-Wl,--exclude-libs=libspdlog.a",
            "-Wl,-soname,libSilKit.so",
            # No -lpthread on QNX (pthreads are in libc)
        ],
        "//bazel:is_linux": [
            "-Wl,--version-script=$(location silkit.map)",
            "-Wl,--exclude-libs=libspdlog.a",
            "-Wl,-soname,libSilKit.so",
            "-lpthread",
        ],
        "//conditions:default": [],
    }),
)

# ===========================================================================
# SilKit dynamic import target
# ---------------------------------------------------------------------------
# Wraps the cc_shared_library output so that cc_binary targets can link
# against libSilKit.so dynamically (matching CMake behaviour for
# sil-kit-system-controller, sil-kit-monitor, and Demos).
# ===========================================================================

cc_import(
    name = "SilKit_dynamic",
    shared_library = ":SilKit",
    deps = ["//SilKit/include:silkit_interface"],
)

