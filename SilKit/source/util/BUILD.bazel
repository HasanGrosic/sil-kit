load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

package(default_visibility = ["//visibility:public"])

# I_SilKit_Util: base utility interface
cc_library(
    name = "silkit_util_interface",
    hdrs = glob(["*.hpp", "tuple_tools/*.hpp"]),
    includes = ["."],
)

# O_SilKit_Util: base utility implementation
cc_library(
    name = "silkit_util",
    srcs = ["ExecutionEnvironment.cpp"],
    deps = [":silkit_util_interface"],
    implementation_deps = [
        "//SilKit/include:silkit_interface",
        ":silkit_util_filehelpers_interface",
        "//ThirdParty:asio",
        "//ThirdParty:fmt",
    ],
    alwayslink = True,
)

