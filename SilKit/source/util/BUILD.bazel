cc_library(
    name = "silkit_util_filehelpers_interface",
    hdrs = ["FileHelpers.hpp"],
    includes = ["."],
    deps = ["//SilKit/include:silkit_interface"],
)

# O_SilKit_Util_FileHelpers
cc_library(
    name = "silkit_util_filehelpers",
    srcs = ["FileHelpers.cpp"],
    deps = [":silkit_util_filehelpers_interface"],
    alwayslink = True,
)

